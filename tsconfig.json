{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"strict": false,
		"noImplicitAny": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "test"]
}
