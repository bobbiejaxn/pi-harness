{
  "name": "pi-harness",
  "version": "1.2.0",
  "description": "Production-hardened subagent execution engine for pi \u2014 circuit breaker, session learning, execution guard, domain enforcement, cost control",
  "author": "Bobbie Jackson",
  "contributors": [
    "Nico Bailon"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobbiejaxn/pi-harness.git"
  },
  "homepage": "https://github.com/bobbiejaxn/pi-harness#readme",
  "bugs": {
    "url": "https://github.com/bobbiejaxn/pi-harness/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagents",
    "ai",
    "agents",
    "cli",
    "circuit-breaker",
    "session-learning"
  ],
  "bin": {
    "pi-harness": "install.mjs"
  },
  "files": [
    "src/**/*.ts",
    "*.mjs",
    "agents/",
    "skills/**/*",
    "prompts/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-transform-types --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.0",
    "jiti": "^2.7.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0"
  }
}
